int swap(int *a, int *b);



void main(void) {
    int aNum[6] = {3,1,4,0,2};
    int size = 5;
    int i = 0, j = 0;
    
    for (i=0;i<(size-1);i++){
        for(j=0;j<(size-1);j++){
            if(aNum[j] < aNum[j+1]){
                swap(&aNum[j],&aNum[j+1]);
            }
        }
    }

    while(1);

    return;
}

int swap(int *a, int *b){
    int temp;
    temp = *b;
    *b = *a;
    *a = temp;

    return 0;
}
